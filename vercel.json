{
    "builds": [
        {
            "src": "backend/main.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "backend/main.py"
        },
        {
            "src": "/webhook",
            "dest": "backend/main.py"
        },
        {
            "src": "/demo/(.*)",
            "dest": "frontend/$1"
        },
        {
            "src": "/demo",
            "dest": "frontend/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "frontend/$1"
        }
    ]
}
