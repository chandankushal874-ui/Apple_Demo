{
    "services": [
        {
            "name": "frontend",
            "root": "frontend",
            "framework": "vite"
        },
        {
            "name": "backend",
            "root": "backend",
            "entrypoint": "main.py"
        }
    ],
    "rewrites": [
        {
            "source": "/api(/.*)?",
            "destination": {
                "type": "service",
                "service": "backend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "type": "service",
                "service": "frontend"
            }
        }
    ]
}
